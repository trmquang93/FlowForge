  },
  "overrides": {
    "@grida/refig": {
      "@grida/canvas-wasm": "0.91.0-canary.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fig-kiwi": "^0.0.1",
    "jsdom": "^28.1.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
